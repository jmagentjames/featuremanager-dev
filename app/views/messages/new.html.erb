<div class="max-w-xl mx-auto">
  <h1 class="text-2xl font-bold text-slate-900 mb-6">Contact</h1>
  <%= form_with model: @message, class: "space-y-4" do |f| %>
    <% if @message.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded">
        <ul class="list-disc list-inside text-sm">
          <% @message.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_field :name, required: true, class: "w-full px-3 py-2 border border-slate-300 rounded focus:outline-none focus:ring-2 focus:ring-sky-500" %>
    </div>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.email_field :email, required: true, class: "w-full px-3 py-2 border border-slate-300 rounded focus:outline-none focus:ring-2 focus:ring-sky-500" %>
    </div>

    <div>
      <%= f.label :body, "Message", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_area :body, required: true, minlength: 10, rows: 5, class: "w-full px-3 py-2 border border-slate-300 rounded focus:outline-none focus:ring-2 focus:ring-sky-500" %>
    </div>

    <%= f.submit "Send Message", class: "px-6 py-2 bg-sky-600 hover:bg-sky-700 text-white font-medium rounded transition-colors" %>
  <% end %>
</div>
