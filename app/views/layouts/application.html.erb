<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <title><%= content_for(:title) || "FeatureManager" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="<%= content_for(:meta_description) || "FeatureManager" %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= yield :head %>

    <!-- Umami Analytics -->
    <script defer src="https://analytics.paddlare.se/script.js" data-website-id="f1834f11-98ba-44c1-a626-e5963963424b"></script>
  </head>
  <body>
    <%= render "shared/header" %>
    <main class="max-w-4xl mx-auto px-4 py-8">
      <% if notice %>
        <p class="notice mb-4 px-4 py-3 bg-green-100 text-green-800 rounded"><%= notice %></p>
      <% end %>
      <% if alert %>
        <p class="alert mb-4 px-4 py-3 bg-red-100 text-red-800 rounded"><%= alert %></p>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
