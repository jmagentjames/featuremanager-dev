<div class="max-w-lg mx-auto mt-10">
  <h1 class="text-2xl font-bold mb-6">Min profil</h1>

  <%= form_with model: Current.user, url: profile_path, method: :patch, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :name, "Namn", class: "block font-medium mb-1" %>
      <%= f.text_field :name, class: "w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.label :email, "E-post", class: "block font-medium mb-1" %>
      <%= f.email_field :email, class: "w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.submit "Spara ändringar", class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 cursor-pointer" %>
    </div>
  <% end %>

  <hr class="my-8">

  <h2 class="text-xl font-bold mb-4 text-red-700">Radera konto</h2>
  <p class="mb-4 text-gray-600">Ange ditt lösenord för att bekräfta borttagning av ditt konto. Denna åtgärd kan inte ångras.</p>

  <%= form_with url: profile_path, method: :delete, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :password, "Lösenord", class: "block font-medium mb-1" %>
      <%= f.password_field :password, class: "w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.submit "Radera mitt konto", class: "bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
