<div class="max-w-md mx-auto">
  <h1 class="text-2xl font-bold text-slate-900 mb-6">Set New Password</h1>
  <%= form_with model: @user, url: password_reset_path(params[:token]), method: :patch, class: "space-y-4" do |f| %>
    <% if @user.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded">
        <ul class="list-disc list-inside text-sm">
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :password, "New password", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.password_field :password, required: true, minlength: 8, class: "w-full px-3 py-2 border border-slate-300 rounded focus:outline-none focus:ring-2 focus:ring-sky-500" %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.password_field :password_confirmation, required: true, class: "w-full px-3 py-2 border border-slate-300 rounded focus:outline-none focus:ring-2 focus:ring-sky-500" %>
    </div>

    <%= f.submit "Reset Password", class: "w-full py-2 bg-sky-600 hover:bg-sky-700 text-white font-medium rounded transition-colors" %>
  <% end %>
</div>
