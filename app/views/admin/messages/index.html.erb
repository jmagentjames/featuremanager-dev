<div class="space-y-4">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-slate-900">Messages</h1>
  </div>

  <% if @messages.empty? %>
    <div class="bg-white border border-dashed border-slate-300 rounded-lg p-8 text-center text-slate-500">
      No messages yet.
    </div>
  <% else %>
    <div class="mb-4">
      <%= button_to "Mark all as read", :mark_all_read_admin_messages, method: :post, class: "text-sm text-sky-600 hover:text-sky-800" %>
    </div>
    <div class="bg-white border border-slate-200 rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">From</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Email</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Preview</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
          <% @messages.each do |message| %>
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-3">
                <% if message.is_read? %>
                  <span class="text-xs font-medium text-slate-400">Read</span>
                <% else %>
                  <span class="inline-block px-2 py-0.5 text-xs font-medium bg-sky-100 text-sky-700 rounded-full">New</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-sm text-slate-900"><%= message.name %></td>
              <td class="px-4 py-3 text-sm text-slate-600"><%= message.email %></td>
              <td class="px-4 py-3 text-sm text-slate-500 truncate max-w-xs">
                <%= link_to message.body.truncate(50), [:admin, message], class: "hover:text-sky-600" %>
              </td>
              <td class="px-4 py-3">
                <% unless message.is_read? %>
                  <%= button_to "Mark read", [:mark_read_admin, message], method: :post, class: "text-xs text-sky-600 hover:text-sky-800" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
