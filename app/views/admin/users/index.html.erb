<div class="space-y-4">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-slate-900">Användare</h1>
  </div>

  <% if @users.empty? %>
    <div class="bg-white border border-dashed border-slate-300 rounded-lg p-8 text-center text-slate-500">
      Inga användare hittades.
    </div>
  <% else %>
    <div class="bg-white border border-slate-200 rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Namn</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">E-post</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Admin</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Skapad</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Åtgärder</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
          <% @users.each do |user| %>
            <%= render "user", user: user %>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
