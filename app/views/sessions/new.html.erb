<div class="max-w-md mx-auto">
  <h1 class="text-2xl font-bold text-slate-900 mb-6">Login</h1>
  <%= form_with url: login_path, scope: :session, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.email_field :email, required: true, autofocus: true, class: "w-full px-3 py-2 border border-slate-300 rounded focus:outline-none focus:ring-2 focus:ring-sky-500" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.password_field :password, required: true, class: "w-full px-3 py-2 border border-slate-300 rounded focus:outline-none focus:ring-2 focus:ring-sky-500" %>
    </div>

    <%= f.submit "Login", class: "w-full py-2 bg-sky-600 hover:bg-sky-700 text-white font-medium rounded transition-colors" %>
  <% end %>

  <p class="mt-4 text-center text-sm text-slate-600">
    <%= link_to "Forgot your password?", new_password_reset_path, class: "text-sky-600 hover:underline" %>
  </p>
</div>
