<tr class="hover:bg-slate-50">
  <td class="px-4 py-3 text-sm text-slate-900"><%= user.name %></td>
  <td class="px-4 py-3 text-sm text-slate-600"><%= user.email %></td>
  <td class="px-4 py-3">
    <% if user.admin? %>
      <span class="inline-block px-2 py-0.5 text-xs font-medium bg-green-100 text-green-700 rounded-full">Ja</span>
    <% else %>
      <span class="text-xs font-medium text-slate-400">Nej</span>
    <% end %>
  </td>
  <td class="px-4 py-3 text-sm text-slate-500"><%= user.created_at.strftime("%Y-%m-%d %H:%M") %></td>
  <td class="px-4 py-3 space-x-2">
    <%= button_to(user.admin? ? "Ta bort admin" : "Gör till admin",
          toggle_admin_admin_user_path(user),
          method: :patch,
          class: "text-xs text-sky-600 hover:text-sky-800") %>
    <%= button_to "Återställ lösenord",
          reset_password_admin_user_path(user),
          method: :post,
          class: "text-xs text-amber-600 hover:text-amber-800" %>
    <% unless user == Current.user %>
      <%= button_to "Ta bort",
            admin_user_path(user),
            method: :delete,
            data: { turbo_confirm: "Är du säker?" },
            class: "text-xs text-red-600 hover:text-red-800" %>
    <% end %>
  </td>
</tr>
