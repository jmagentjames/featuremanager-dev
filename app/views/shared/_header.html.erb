<%# app/views/shared/_header.html.erb %>
<header class="bg-white border-b border-slate-200">
  <div class="max-w-4xl mx-auto px-4">
    <nav class="flex items-center gap-6 h-16">
      <%= link_to "FeatureManager", root_path, class: "font-semibold text-slate-900 hover:text-sky-600 transition-colors" %>

      <div class="flex-1"></div>

      <% if Current.user %>
        <% if Current.user&.admin? %>
          <%= link_to "Admin", admin_root_path, class: "text-sm font-medium text-slate-600 hover:text-sky-600 transition-colors" %>
          <% unread = Message.unread.count %>
          <% if unread > 0 %>
            <span class="px-2 py-1 text-xs font-medium bg-sky-100 text-sky-700 rounded-full"><%= unread %> unread</span>
          <% end %>
        <% end %>
        <span class="text-sm text-slate-600"><%= Current.user.name %></span>
        <%= button_to "Logout", logout_path, method: :delete, class: "text-sm text-slate-600 hover:text-sky-600 transition-colors" %>
      <% else %>
        <%= link_to "Login", login_path, class: "text-sm font-medium text-slate-600 hover:text-sky-600 transition-colors" %>
        <%= link_to "Sign up", signup_path, class: "text-sm font-medium text-sky-600 hover:text-sky-600 transition-colors" %>
      <% end %>
    </nav>
  </div>
</header>
