<div class="max-w-md mx-auto">
  <h1 class="text-2xl font-bold text-slate-900 mb-6">Reset Password</h1>
  <p class="text-sm text-slate-600 mb-4">Enter your email and we'll send you a reset link.</p>
  <%= form_with url: password_reset_path, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.email_field :email, required: true, autofocus: true, class: "w-full px-3 py-2 border border-slate-300 rounded focus:outline-none focus:ring-2 focus:ring-sky-500" %>
    </div>
    <%= f.submit "Send Reset Link", class: "w-full py-2 bg-sky-600 hover:bg-sky-700 text-white font-medium rounded transition-colors" %>
  <% end %>
</div>
