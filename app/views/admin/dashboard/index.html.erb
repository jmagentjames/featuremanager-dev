<div class="space-y-6">
  <h1 class="text-2xl font-bold text-slate-900">Admin Dashboard</h1>

  <div class="grid grid-cols-2 gap-4">
    <a href="<%= admin_messages_path %>" class="bg-white border border-slate-200 rounded-lg p-6 hover:border-sky-300 hover:shadow-sm transition-colors">
      <div class="text-3xl font-bold text-sky-600"><%= @unread_messages %></div>
      <div class="text-sm text-slate-500 mt-1">Unread messages</div>
    </a>
    <a href="<%= admin_users_path %>" class="bg-white border border-slate-200 rounded-lg p-6 hover:border-emerald-300 hover:shadow-sm transition-colors">
      <div class="text-3xl font-bold text-emerald-600"><%= @total_users %></div>
      <div class="text-sm text-slate-500 mt-1">Users</div>
    </a>
  </div>
</div>
